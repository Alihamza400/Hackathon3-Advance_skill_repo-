# LearnFlow — Generic Microservice Docker Image
FROM python:3.12-slim

WORKDIR /app
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

COPY services/requirements.txt /tmp/
RUN pip install --no-cache-dir -r /tmp/requirements.txt

COPY services/ ./services/

ENV PYTHONPATH=/app/services
EXPOSE 8000
CMD ["sh", "-c", "exec python services/${SERVICE_NAME}/main.py"]
